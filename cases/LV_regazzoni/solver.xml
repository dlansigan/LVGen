<?xml version="1.0" encoding="UTF-8" ?>
<svMultiPhysicsFile version="0.1">

<GeneralSimulationParameters>

  <Continue_previous_simulation> false </Continue_previous_simulation>
  <Number_of_spatial_dimensions> 3 </Number_of_spatial_dimensions> 
  <Number_of_time_steps> 1024 </Number_of_time_steps> 
  <Time_step_size> 0.005388 </Time_step_size> 
  <Spectral_radius_of_infinite_time_step> 0.50 </Spectral_radius_of_infinite_time_step> 
  <Searched_file_name_to_trigger_stop> STOP_SIM </Searched_file_name_to_trigger_stop> 

  <Save_results_to_VTK_format> 1 </Save_results_to_VTK_format> 
  <Name_prefix_of_saved_VTK_files> result </Name_prefix_of_saved_VTK_files> 
  <Increment_in_saving_VTK_files> 4 </Increment_in_saving_VTK_files> 
  <Start_saving_after_time_step> 1 </Start_saving_after_time_step> 

  <Increment_in_saving_restart_files> 200 </Increment_in_saving_restart_files> 
  <Convert_BIN_to_VTK_format> 0 </Convert_BIN_to_VTK_format> 

  <Verbose> 1 </Verbose> 
  <Warning> 0 </Warning> 
  <Debug> 0 </Debug> 

</GeneralSimulationParameters>

<Add_mesh name="LV" > 

  <Mesh_file_path> mesh/mesh_complete.vtu </Mesh_file_path>

  <Add_face name="LV_wall">
      <Face_file_path> mesh/mesh-surfaces/wall.vtp </Face_file_path>
  </Add_face>

  <Add_face name="LV_inlet">
      <Face_file_path> mesh/mesh-surfaces/mv.vtp </Face_file_path>
  </Add_face>

  <Add_face name="LV_outlet">
      <Face_file_path> mesh/mesh-surfaces/av.vtp </Face_file_path>
  </Add_face>
  <Domain> 0 </Domain>

</Add_mesh>

<Add_equation type="FSI" > 
   <Coupled> true </Coupled>
   <Min_iterations> 1 </Min_iterations>  
   <Max_iterations> 10</Max_iterations> 
   <Tolerance> 1e-4 </Tolerance> 

   <Domain id="0" >
      <Equation> fluid </Equation> 
      <Density> 1.06 </Density> 
      <Viscosity model="Constant" >
         <Value> 0.04 </Value>
      </Viscosity>
      <Backflow_stabilization_coefficient> 0.3 </Backflow_stabilization_coefficient> 
   </Domain>

   <Output type="Spatial" >
      <Velocity> true </Velocity>
      <Pressure> true </Pressure>
      <Vorticity> true</Vorticity>
      <Divergence> true</Divergence>
      <WSS> true </WSS>
   </Output>

   <Output type="B_INT" >
     <Pressure> true </Pressure>
     <Velocity> true </Velocity>
   </Output>

   <LS type="GMRES" >
      <Linear_algebra type="fsils" >
         <Preconditioner> fsils </Preconditioner>
      </Linear_algebra>
      <Tolerance> 1e-5 </Tolerance>
      <Max_iterations> 100 </Max_iterations> 
      <Krylov_space_dimension> 50 </Krylov_space_dimension>
   </LS>

   <svZeroDSolver_interface> 
     <Coupling_type> semi-implicit </Coupling_type>
     <Configuration_file> svzerod_3Dcoupling.json </Configuration_file>
     <Shared_library> ../../../svZeroDSolver/debug/src/interface/libsvzero_interface.so </Shared_library>  
     <Initial_flows> 0.0 </Initial_flows>
     <Initial_pressures> 0.0 </Initial_pressures>
   </svZeroDSolver_interface> 

   <Add_BC name="LV_inlet" > 
      <Type> Neu </Type> 
      <!-- <Value> 0 </Value> -->
      <Time_dependence> Coupled </Time_dependence> 
      <svZeroDSolver_block> LPN_outlet </svZeroDSolver_block>  
   </Add_BC> 

   <Add_BC name="LV_outlet" > 
      <Type> Neu </Type> 
      <!-- <Value> 0 </Value> -->
      <Time_dependence> Coupled </Time_dependence> 
      <svZeroDSolver_block> LPN_inlet </svZeroDSolver_block>  
   </Add_BC> 
   
   <Add_BC name="LV_wall" > 
      <Type> Dir </Type> 
      <!-- <Value> 0 </Value> -->
      <Time_dependence> General </Time_dependence> 
      <Temporal_and_spatial_values_file_path>mesh/motion/1_displacement.dat</Temporal_and_spatial_values_file_path> 
      <Profile> Flat </Profile>
      <Zero_out_perimeter> false </Zero_out_perimeter>
      <Impose_flux> false </Impose_flux> 
      <Impose_on_state_variable_integral> true </Impose_on_state_variable_integral>
   </Add_BC> 

</Add_equation>


<Add_equation type="mesh" >
   <Coupled> true </Coupled>
   <Min_iterations> 1 </Min_iterations>
   <Max_iterations> 5 </Max_iterations>
   <Tolerance> 1e-6 </Tolerance>
   <Poisson_ratio> 0. </Poisson_ratio> 

   <LS type="CG" >
      <Linear_algebra type="fsils" >
         <Preconditioner> fsils </Preconditioner>
      </Linear_algebra>
      <Tolerance> 1e-4 </Tolerance>
   </LS>

   <Output type="Spatial" >
     <Displacement> true </Displacement>
   </Output>

   <Add_BC name="LV_wall" > 
      <Type> Dir </Type>  
      <!-- <Value> 0 </Value> -->
      <Time_dependence> General </Time_dependence> 
      <Temporal_and_spatial_values_file_path>mesh/motion/1_displacement.dat</Temporal_and_spatial_values_file_path> 
      <Profile> Flat </Profile>
      <Zero_out_perimeter> false </Zero_out_perimeter>
      <Impose_flux> false </Impose_flux> 
      <Impose_on_state_variable_integral> true </Impose_on_state_variable_integral>
   </Add_BC> 

   <Add_BC name="LV_inlet" > 
      <Type> Dir </Type> 
      <!-- <Value> 0 </Value> -->
      <Time_dependence> General </Time_dependence> 
      <Temporal_and_spatial_values_file_path>mesh/motion/3_displacement.dat</Temporal_and_spatial_values_file_path> 
      <Profile> Flat </Profile>
      <Zero_out_perimeter> false </Zero_out_perimeter>
      <Impose_flux> false </Impose_flux> 
      <Impose_on_state_variable_integral> true </Impose_on_state_variable_integral>
   </Add_BC> 

   <Add_BC name="LV_outlet" > 
      <Type> Dir </Type> 
      <!-- <Value> 0 </Value> -->
      <Time_dependence> General </Time_dependence> 
      <Temporal_and_spatial_values_file_path>mesh/motion/2_displacement.dat</Temporal_and_spatial_values_file_path> 
      <Profile> Flat </Profile>
      <Zero_out_perimeter> false </Zero_out_perimeter>
      <Impose_flux> false </Impose_flux> 
      <Impose_on_state_variable_integral> true </Impose_on_state_variable_integral>
   </Add_BC> 

</Add_equation>

</svMultiPhysicsFile>


